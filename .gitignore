# Node
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment / secrets
.env
*.env
.env.local
.env.*.local

# Claude Code local settings (per-machine, not for the repo)
.claude/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Pipeline cache (fetched HTML, per-run diff markdown)
cache/

# Pipeline transient snapshot (regenerated each run by the workflow)
data/pet_airlines_v0.1.previous.json

# VSCode — local user settings only; shared workspace configs are committed
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains IDEs — local user files only; shared run configs are committed
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/shelf/
*.iml

# Logs
*.log

# Hugging Face Datasets
# The hf/ directory itself IS committed to GitHub — it is the canonical source
# of the HF Dataset Card and the bit-identical snapshot uploaded to HF.
# However, HF tooling may auto-generate per-machine artifacts inside hf/ that
# do not belong in the GitHub repo. Add such files here per-file as they appear:
# hf/dataset_infos.json
# hf/.huggingface/

# Internal strategy docs — never commit
/internal/
*-internal.md
